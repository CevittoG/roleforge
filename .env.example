# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=12000

# --- Google OAuth (own-account refresh token) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Google resources ---
DRIVE_EXPERIENCE_FOLDER_ID=
DRIVE_OUTPUT_ROOT_FOLDER_ID=
SHEET_ID=
SHEET_TAB=Applications
SHEET_SKILLS_TAB=Skills
# Optional deep-link to a user-created `Insights` tab containing a =QUERY
# formula over Skills!A:F (see README). Surfaced as a footer link on /history.
SHEET_INSIGHTS_URL=

# --- Cloudflare Access ---
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=

# --- Origin lock (header value Cloudflare injects) ---
ORIGIN_SHARED_SECRET=

# --- Guardrails ---
MAX_JD_CHARS=30000
ENVIRONMENT=production
# Default ON. Set to false in a local .env to skip Cloudflare Access / origin
# checks while developing. NEVER set to false in production.
AUTH_REQUIRED=true
