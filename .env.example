# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=12000

# --- Google Gemini (optional second LLM provider; free tier) ---
# Leave GEMINI_API_KEY blank to disable Gemini entirely: the UI hides the model
# selector and every run uses Anthropic. Distinct from the GOOGLE_* OAuth creds
# below (that's Drive/Sheets; this is the Gemini API).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_TOKENS=12000
# Which provider the UI pre-selects (anthropic | gemini). Falls back to an
# available provider if the chosen one has no API key configured.
DEFAULT_LLM_PROVIDER=gemini

# --- Resume header (contact identity) ---
# Injected verbatim into the resume header and the cover-letter signature; NEVER
# generated by the model (contact data must not be hallucinated). Leave a field
# blank to omit it. RESUME_LINKS is comma-separated (LinkedIn, portfolio, …).
RESUME_FULL_NAME=
RESUME_EMAIL=
RESUME_PHONE=
RESUME_LOCATION=
RESUME_LINKS=

# --- Google OAuth (own-account refresh token) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Google resources ---
DRIVE_EXPERIENCE_FOLDER_ID=
DRIVE_OUTPUT_ROOT_FOLDER_ID=
SHEET_ID=
SHEET_TAB=Applications
SHEET_SKILLS_TAB=Skills
# Optional deep-link to a user-created `Insights` tab containing a =QUERY
# formula over Skills!A:F (see README). Surfaced as a footer link on /history.
SHEET_INSIGHTS_URL=

# --- Cloudflare Access ---
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=

# --- Origin lock (header value Cloudflare injects) ---
ORIGIN_SHARED_SECRET=

# --- Guardrails ---
MAX_JD_CHARS=30000
ENVIRONMENT=production
# Default ON. Set to false in a local .env to skip Cloudflare Access / origin
# checks while developing. NEVER set to false in production.
AUTH_REQUIRED=true
